<Window x:Class="LAMP_DAQ_Control_v0_8.UI.WPF.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:LAMP_DAQ_Control_v0_8.UI.WPF.ViewModels"
        xmlns:views="clr-namespace:LAMP_DAQ_Control_v0_8.UI.WPF.Views"
        Title="LAMP DAQ Control v0.8 - Visualización en Tiempo Real" 
        Height="800" Width="1400"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized">
    
    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>
    
    <Window.Resources>
        <!-- Estilos locales -->
        <Style x:Key="HeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
    </Window.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Header -->
            <RowDefinition Height="*"/>      <!-- Content -->
            <RowDefinition Height="Auto"/>   <!-- Status Bar -->
        </Grid.RowDefinitions>
        
        <!-- HEADER -->
        <Border Grid.Row="0" Background="#2C3E50" Padding="15,10">
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <TextBlock Text="LAMP DAQ Control v0.8" 
                              Style="{StaticResource HeaderStyle}"/>
                    <TextBlock Text=" | " 
                              Style="{StaticResource HeaderStyle}" 
                              Margin="10,0"/>
                    <TextBlock Text="Monitoreo en Tiempo Real" 
                              Style="{StaticResource HeaderStyle}"
                              Foreground="#3498DB"/>
                </StackPanel>
                
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right">
                    <Button Content="🔄 Refrescar" 
                            Command="{Binding RefreshDevicesCommand}"
                            Background="#3498DB" 
                            Foreground="White"
                            BorderThickness="0"
                            Padding="15,5"
                            Margin="5,0"
                            Cursor="Hand"/>
                    <Button Content="❌ Salir" 
                            Command="{Binding ExitCommand}"
                            Background="#E74C3C" 
                            Foreground="White"
                            BorderThickness="0"
                            Padding="15,5"
                            Margin="5,0"
                            Cursor="Hand"/>
                </StackPanel>
            </DockPanel>
        </Border>
        
        <!-- CONTENT -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>  <!-- Sidebar -->
                <ColumnDefinition Width="*"/>    <!-- Main Content -->
            </Grid.ColumnDefinitions>
            
            <!-- SIDEBAR -->
            <Border Grid.Column="0" 
                    BorderBrush="#BDC3C7" 
                    BorderThickness="0,0,1,0"
                    Background="#ECF0F1">
                <StackPanel Margin="15">
                    <TextBlock Text="DISPOSITIVOS DETECTADOS" 
                              FontWeight="Bold" 
                              FontSize="14" 
                              Margin="0,0,0,15"
                              Foreground="#2C3E50"/>
                    
                    <ListBox ItemsSource="{Binding Devices}"
                            SelectedItem="{Binding SelectedDevice}"
                            Height="200"
                            Background="White"
                            BorderBrush="#95A5A6">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="5">
                                    <TextBlock Text="{Binding Name}" 
                                              FontWeight="Bold"
                                              FontSize="12"/>
                                    <TextBlock Text="{Binding DeviceType}" 
                                              FontSize="10"
                                              Foreground="#7F8C8D"/>
                                    <TextBlock FontSize="10" Foreground="#95A5A6">
                                        <Run Text="Board ID: "/>
                                        <Run Text="{Binding BoardId}"/>
                                    </TextBlock>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    
                    <Separator Margin="0,20"/>
                    
                    <TextBlock Text="DISPOSITIVO ACTUAL" 
                              FontWeight="Bold" 
                              FontSize="12" 
                              Margin="0,0,0,10"
                              Foreground="#2C3E50"/>
                    
                    <Border Background="White" 
                            BorderBrush="#95A5A6" 
                            BorderThickness="1" 
                            Padding="10"
                            CornerRadius="5">
                        <StackPanel>
                            <TextBlock Text="{Binding DeviceTypeText}" 
                                      TextWrapping="Wrap"
                                      FontSize="11"/>
                            <TextBlock Text="Estado: " 
                                      FontSize="10" 
                                      Margin="0,5,0,0">
                                <Run Text="{Binding StatusMessage}" 
                                     Foreground="#27AE60"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
            
            <!-- MAIN CONTENT AREA - SOLO UNO A LA VEZ -->
            <ContentControl Grid.Column="1" Margin="10">
                <ContentControl.Style>
                    <Style TargetType="ContentControl">
                        <!-- Por defecto: mensaje -->
                        <Setter Property="Content">
                            <Setter.Value>
                                <Border VerticalAlignment="Center" 
                                        HorizontalAlignment="Center"
                                        Padding="40"
                                        Background="#ECF0F1"
                                        CornerRadius="10">
                                    <StackPanel>
                                        <TextBlock Text="⚠" FontSize="48" HorizontalAlignment="Center" Foreground="#95A5A6"/>
                                        <TextBlock Text="Seleccione un dispositivo" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,10,0,5" Foreground="#7F8C8D"/>
                                        <TextBlock Text="Use el panel lateral para seleccionar un dispositivo DAQ" FontSize="12" HorizontalAlignment="Center" Foreground="#95A5A6"/>
                                    </StackPanel>
                                </Border>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <!-- Si es Analógico: mostrar panel analógico -->
                            <DataTrigger Binding="{Binding IsAnalogDevice}" Value="True">
                                <Setter Property="Content">
                                    <Setter.Value>
                                        <views:AnalogControlPanel DataContext="{Binding AnalogControl}"/>
                                    </Setter.Value>
                                </Setter>
                            </DataTrigger>
                            <!-- Si es Digital: mostrar panel digital -->
                            <DataTrigger Binding="{Binding IsDigitalDevice}" Value="True">
                                <Setter Property="Content">
                                    <Setter.Value>
                                        <views:DigitalControlPanel DataContext="{Binding DigitalMonitor}"/>
                                    </Setter.Value>
                                </Setter>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ContentControl.Style>
            </ContentControl>
        </Grid>
        
        <!-- STATUS BAR -->
        <Border Grid.Row="2" 
                Background="#34495E" 
                Padding="10,5">
            <DockPanel>
                <TextBlock Text="Estado: " 
                          Foreground="White" 
                          FontWeight="Bold"
                          DockPanel.Dock="Left"/>
                <TextBlock Text="{Binding StatusMessage}" 
                          Foreground="#3498DB"
                          DockPanel.Dock="Left"/>
                <TextBlock Text="{Binding Source={x:Static sys:DateTime.Now}, StringFormat='HH:mm:ss'}" 
                          xmlns:sys="clr-namespace:System;assembly=mscorlib"
                          Foreground="White" 
                          DockPanel.Dock="Right"
                          HorizontalAlignment="Right"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
