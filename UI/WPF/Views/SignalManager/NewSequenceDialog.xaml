<Window x:Class="LAMP_DAQ_Control_v0_8.UI.WPF.Views.SignalManager.NewSequenceDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="New Sequence" 
        Height="300" 
        Width="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="#F5F5F5">
    
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Sequence Name -->
        <StackPanel Grid.Row="0">
            <TextBlock Text="Sequence Name:" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBox x:Name="SequenceNameTextBox" 
                     Text="My Sequence" 
                     Padding="5"
                     FontSize="12"/>
        </StackPanel>

        <!-- Duration -->
        <StackPanel Grid.Row="2">
            <TextBlock Text="Duration (seconds):" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBox x:Name="DurationTextBox" 
                     Text="10" 
                     Padding="5"
                     FontSize="12"/>
        </StackPanel>

        <!-- Description -->
        <StackPanel Grid.Row="4">
            <TextBlock Text="Description (optional):" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBox x:Name="DescriptionTextBox" 
                     Text="" 
                     Padding="5"
                     Height="50"
                     TextWrapping="Wrap"
                     AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto"
                     FontSize="12"/>
        </StackPanel>

        <!-- Buttons -->
        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Create" 
                    Width="80" 
                    Height="30" 
                    Margin="0,0,10,0"
                    IsDefault="True"
                    Click="OnCreate"
                    Background="#4CAF50"
                    Foreground="White"
                    FontWeight="Bold"
                    BorderThickness="0"
                    Cursor="Hand"/>
            <Button Content="Cancel" 
                    Width="80" 
                    Height="30"
                    IsCancel="True"
                    Click="OnCancel"
                    Background="#E0E0E0"
                    Foreground="#333"
                    BorderThickness="0"
                    Cursor="Hand"/>
        </StackPanel>
    </Grid>
    </ScrollViewer>
</Window>
