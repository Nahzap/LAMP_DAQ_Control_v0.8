<Window x:Class="LAMP_DAQ_Control_v0_8.UI.WPF.Views.SignalManager.SignalManagerView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:controls="clr-namespace:LAMP_DAQ_Control_v0_8.UI.WPF.Controls"
        mc:Ignorable="d"
        Title="Signal Manager - LAMP DAQ Control" Height="700" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Menu Bar -->
            <RowDefinition Height="*"/>
            <!-- Content -->
            <RowDefinition Height="Auto"/>
            <!-- Status Bar -->
        </Grid.RowDefinitions>

        <!-- Menu Bar -->
        <Menu Grid.Row="0" Background="White" Padding="5">
            <MenuItem Header="_File">
                <MenuItem Header="_New Sequence" Command="{Binding NewSequenceCommand}"/>
                <MenuItem Header="_Open Sequence..." Command="{Binding OpenSequenceCommand}"/>
                <MenuItem Header="_Save Sequence" Command="{Binding SaveSequenceCommand}"/>
                <MenuItem Header="Save Sequence _As..." Command="{Binding SaveSequenceAsCommand}"/>
                <Separator/>
                <MenuItem Header="_Close" Command="{Binding CloseCommand}"/>
            </MenuItem>
            <MenuItem Header="_Edit">
                <MenuItem Header="_Add Event" Command="{Binding AddEventCommand}"/>
                <MenuItem Header="_Delete Event" Command="{Binding DeleteEventCommand}"/>
                <MenuItem Header="D_uplicate Event" Command="{Binding DuplicateEventCommand}"/>
            </MenuItem>
            <MenuItem Header="_Sequence">
                <MenuItem Header="_Validate" Command="{Binding ValidateCommand}"/>
                <MenuItem Header="_Execute" Command="{Binding ExecuteCommand}"/>
                <MenuItem Header="_Stop" Command="{Binding StopCommand}"/>
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="_About"/>
            </MenuItem>
        </Menu>

        <!-- Main Content -->
        <Grid Grid.Row="1" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/>
                <!-- Left Panel -->
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
                <!-- Center (Timeline) -->
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="300"/>
                <!-- Right Panel -->
            </Grid.ColumnDefinitions>

            <!-- Left Panel: Sequences & Library -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Sequences Section -->
                <TextBlock Grid.Row="0" Text="Sequences" FontWeight="Bold" FontSize="14" Margin="0,0,0,5"/>
                <Border Grid.Row="1" BorderBrush="#DDD" BorderThickness="1" Background="White" Margin="0,0,0,10">
                    <ListBox ItemsSource="{Binding Sequences}" 
                             SelectedItem="{Binding SelectedSequence}"
                             DisplayMemberPath="Name"/>
                </Border>

                <!-- Signal Library Section -->
                <TextBlock Grid.Row="2" Text="Signal Library" FontWeight="Bold" FontSize="14" Margin="0,10,0,5"/>
                <Border Grid.Row="3" BorderBrush="#DDD" BorderThickness="1" Background="White">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <TreeView ItemsSource="{Binding SignalCategories}" 
                                  IsEnabled="{Binding IsSequenceSelected}"
                                  Background="White">
                        <TreeView.ItemContainerStyle>
                            <Style TargetType="TreeViewItem">
                                <Setter Property="IsExpanded" Value="True"/>
                                <Setter Property="Padding" Value="2"/>
                            </Style>
                        </TreeView.ItemContainerStyle>
                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate ItemsSource="{Binding Signals}">
                                <TextBlock Text="{Binding CategoryName}" 
                                           FontWeight="Bold" 
                                           FontSize="12"
                                           Foreground="#2C3E50"
                                           Margin="0,5,0,3"/>
                                <HierarchicalDataTemplate.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#E8F4F8" 
                                                Padding="8,4" 
                                                Margin="2,1" 
                                                CornerRadius="3"
                                                BorderBrush="#B0D4E3"
                                                BorderThickness="1"
                                                Cursor="Hand"
                                                MouseDown="OnSignalMouseDown"
                                                Tag="{Binding}">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#D0E8F2"/>
                                                            <Setter Property="BorderBrush" Value="#5DADE2"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding Name}" 
                                                       FontSize="11"
                                                       Foreground="#34495E"/>
                                        </Border>
                                    </DataTemplate>
                                </HierarchicalDataTemplate.ItemTemplate>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                    </ScrollViewer>
                </Border>
            </Grid>

            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" Background="#DDD"/>

            <!-- Center Panel: Timeline -->
            <Border Grid.Column="2" BorderBrush="#DDD" BorderThickness="1" Background="White">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <!-- Controls -->
                        <RowDefinition Height="*"/>
                        <!-- Timeline -->
                    </Grid.RowDefinitions>

                    <!-- Playback Controls -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Background="#F9F9F9" Margin="10">
                        <Button Content="▶ Play" Command="{Binding PlayCommand}" Width="80" Margin="0,0,5,0"/>
                        <Button Content="⏸ Pause" Command="{Binding PauseCommand}" Width="80" Margin="0,0,5,0"/>
                        <Button Content="⏹ Stop" Command="{Binding StopCommand}" Width="80" Margin="0,0,10,0"/>
                        <CheckBox Content="Loop Control" IsChecked="{Binding IsLoopEnabled}" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="Bold"/>
                        <Border BorderBrush="#27AE60" BorderThickness="2" CornerRadius="3" Padding="8,2" Background="#D5F4E6" Margin="0,0,20,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⚡" FontSize="14" VerticalAlignment="Center" Margin="0,0,5,0" Foreground="#27AE60"/>
                                <TextBlock Text="{Binding ExecutionMode}" 
                                           VerticalAlignment="Center" 
                                           FontSize="12"
                                           FontWeight="Bold"
                                           Foreground="#229954"/>
                            </StackPanel>
                        </Border>
                        <TextBlock Text="Time:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <TextBlock Text="{Binding CurrentTimeText}" VerticalAlignment="Center" FontWeight="Bold" MinWidth="60"/>
                        <Slider Value="{Binding CurrentTimeSeconds}" 
                                Maximum="{Binding TotalDurationSeconds}" 
                                Width="200" 
                                Margin="10,0,20,0"
                                VerticalAlignment="Center"/>
                        <TextBlock Text="Zoom:" VerticalAlignment="Center" Margin="0,0,5,0" FontWeight="Bold"/>
                        <Button Content="−" Command="{Binding ZoomOutCommand}" Width="30" Margin="0,0,3,0" FontSize="16" FontWeight="Bold"/>
                        <TextBlock Text="{Binding ZoomLevelText, StringFormat={}  {0}X  }" VerticalAlignment="Center" MinWidth="50" TextAlignment="Center" FontWeight="Bold" FontSize="11"/>
                        <Button Content="+" Command="{Binding ZoomInCommand}" Width="30" Margin="3,0,0,0" FontSize="16" FontWeight="Bold"/>
                    </StackPanel>

                    <!-- Timeline View with Custom Control -->
                    <controls:TimelineControl Grid.Row="1" x:Name="TimelineControl" DataContext="{Binding}" MinHeight="400"/>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="3" Width="5" HorizontalAlignment="Stretch" Background="#DDD"/>

            <!-- Right Panel: Event Details & Events List -->
            <Grid Grid.Column="4">
                <TabControl>
                    <!-- Event Details Tab -->
                    <TabItem Header="Event Details">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                
                            <Border Grid.Row="1" BorderBrush="#DDD" BorderThickness="1" Background="White" Padding="10">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <StackPanel>
                                        <TextBlock Text="Name:" FontWeight="Bold" Margin="0,0,0,5"/>
                                        <TextBox Text="{Binding SelectedEvent.Name, UpdateSourceTrigger=PropertyChanged}" 
                                                 Margin="0,0,0,10"/>

                                        <TextBlock Text="Event Type:" FontWeight="Bold" Margin="0,0,0,5"/>
                                        <ComboBox ItemsSource="{Binding EventTypes}"
                                                  SelectedItem="{Binding SelectedEvent.EventType}" 
                                                  Margin="0,0,0,10"/>

                                        <TextBlock Text="Channel:" FontWeight="Bold" Margin="0,0,0,5"/>
                                        <TextBox Text="{Binding SelectedEvent.Channel, UpdateSourceTrigger=PropertyChanged}" 
                                                 Margin="0,0,0,10"/>

                                        <TextBlock Text="Start Time (s):" FontWeight="Bold" Margin="0,0,0,5"/>
                                        <TextBox Text="{Binding SelectedEventStartSeconds, UpdateSourceTrigger=PropertyChanged}" 
                                                 Margin="0,0,0,10"/>

                                        <TextBlock Text="Duration (ms):" FontWeight="Bold" Margin="0,0,0,5"/>
                                        <TextBox Text="{Binding SelectedEventDurationMs, UpdateSourceTrigger=PropertyChanged}" 
                                                 Margin="0,0,0,10"/>

                                        <!-- Start Voltage for Ramp events -->
                                        <TextBlock Text="Start Voltage (V):" FontWeight="Bold" Margin="0,0,0,5"
                                                   Visibility="{Binding SelectedEventHasRampVoltages, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                        <TextBox Text="{Binding SelectedEventStartVoltage, UpdateSourceTrigger=PropertyChanged}" 
                                                 Margin="0,0,0,10"
                                                 Visibility="{Binding SelectedEventHasRampVoltages, Converter={StaticResource BoolToVisibilityConverter}}"/>

                                        <!-- End Voltage for Ramp events -->
                                        <TextBlock Text="End Voltage (V):" FontWeight="Bold" Margin="0,0,0,5"
                                                   Visibility="{Binding SelectedEventHasRampVoltages, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                        <TextBox Text="{Binding SelectedEventEndVoltage, UpdateSourceTrigger=PropertyChanged}" 
                                                 Margin="0,0,0,10"
                                                 Visibility="{Binding SelectedEventHasRampVoltages, Converter={StaticResource BoolToVisibilityConverter}}"/>

                                        <!-- Waveform Parameters -->
                                        <TextBlock Text="Frequency (Hz):" FontWeight="Bold" Margin="0,0,0,5"
                                                   Visibility="{Binding SelectedEventHasWaveformParams, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                        <TextBox Text="{Binding SelectedEventFrequency, UpdateSourceTrigger=PropertyChanged}" 
                                                 Margin="0,0,0,10"
                                                 Visibility="{Binding SelectedEventHasWaveformParams, Converter={StaticResource BoolToVisibilityConverter}}"/>

                                        <TextBlock Text="Amplitude (V):" FontWeight="Bold" Margin="0,0,0,5"
                                                   Visibility="{Binding SelectedEventHasWaveformParams, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                        <TextBox Text="{Binding SelectedEventAmplitude, UpdateSourceTrigger=PropertyChanged}" 
                                                 Margin="0,0,0,10"
                                                 Visibility="{Binding SelectedEventHasWaveformParams, Converter={StaticResource BoolToVisibilityConverter}}"/>

                                        <TextBlock Text="Offset (V):" FontWeight="Bold" Margin="0,0,0,5"
                                                   Visibility="{Binding SelectedEventHasWaveformParams, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                        <TextBox Text="{Binding SelectedEventOffset, UpdateSourceTrigger=PropertyChanged}" 
                                                 Margin="0,0,0,10"
                                                 Visibility="{Binding SelectedEventHasWaveformParams, Converter={StaticResource BoolToVisibilityConverter}}"/>

                                        <!-- Digital State (HIGH/LOW) -->
                                        <TextBlock Text="Digital State:" FontWeight="Bold" Margin="0,0,0,5"
                                                   Visibility="{Binding SelectedEventIsDigitalState, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                        <ComboBox SelectedItem="{Binding SelectedEventDigitalState, UpdateSourceTrigger=PropertyChanged}" 
                                                  Margin="0,0,0,10"
                                                  Visibility="{Binding SelectedEventIsDigitalState, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <ComboBoxItem Content="HIGH"/>
                                            <ComboBoxItem Content="LOW"/>
                                        </ComboBox>

                                        <!-- Pulse Train Parameters -->
                                        <TextBlock Text="Frequency (Hz):" FontWeight="Bold" Margin="0,0,0,5"
                                                   Visibility="{Binding SelectedEventIsPulseTrain, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                        <TextBox Text="{Binding SelectedEventFrequency, UpdateSourceTrigger=PropertyChanged}" 
                                                 Margin="0,0,0,10"
                                                 Visibility="{Binding SelectedEventIsPulseTrain, Converter={StaticResource BoolToVisibilityConverter}}"/>

                                        <TextBlock Text="Duty Cycle (%):" FontWeight="Bold" Margin="0,0,0,5"
                                                   Visibility="{Binding SelectedEventIsPulseTrain, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                        <TextBox Text="{Binding SelectedEventDutyCycle, UpdateSourceTrigger=PropertyChanged}" 
                                                 Margin="0,0,0,10"
                                                 Visibility="{Binding SelectedEventIsPulseTrain, Converter={StaticResource BoolToVisibilityConverter}}"/>

                                        <TextBlock Text="vHigh (V):" FontWeight="Bold" Margin="0,0,0,5"
                                                   Visibility="{Binding SelectedEventIsPulseTrain, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                        <ComboBox SelectedItem="{Binding SelectedEventVHigh, UpdateSourceTrigger=PropertyChanged}" 
                                                  Margin="0,0,0,10"
                                                  Visibility="{Binding SelectedEventIsPulseTrain, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <ComboBoxItem Content="3.3"/>
                                            <ComboBoxItem Content="5.0"/>
                                        </ComboBox>

                                        <TextBlock Text="Description:" FontWeight="Bold" Margin="0,0,0,5"/>
                                        <TextBox Text="{Binding SelectedEvent.Description, UpdateSourceTrigger=PropertyChanged}" 
                                                 TextWrapping="Wrap" 
                                                 AcceptsReturn="True" 
                                                 Height="60" 
                                                 Margin="0,0,0,10"/>

                                        <Button Content="Apply Changes" Command="{Binding ApplyEventChangesCommand}" 
                                                HorizontalAlignment="Stretch" 
                                                Padding="10,5"/>
                                    </StackPanel>
                                </ScrollViewer>
                            </Border>

                            <StackPanel Grid.Row="2" Margin="0,10,0,0">
                                <Button Content="Delete Event" Command="{Binding DeleteEventCommand}" 
                                        Background="#E74C3C" Foreground="White" 
                                        Padding="10,5" Margin="0,0,0,5"/>
                                <Button Content="Duplicate Event" Command="{Binding DuplicateEventCommand}" 
                                        Padding="10,5"/>
                            </StackPanel>
                        </Grid>
                    </TabItem>
                    
                    <!-- Events List Tab -->
                    <TabItem Header="Events List">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            
                            <TextBlock Grid.Row="0" Text="All Events as Objects" FontWeight="Bold" FontSize="14" Margin="10"/>
                            
                            <DataGrid Grid.Row="1" ItemsSource="{Binding EventsList}" 
                                      AutoGenerateColumns="False" 
                                      CanUserAddRows="False"
                                      SelectionMode="Single"
                                      SelectedItem="{Binding SelectedEventFromList, Mode=TwoWay}"
                                      Margin="10">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Name" Binding="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" Width="90" IsReadOnly="False"/>
                                    <DataGridTextColumn Header="Ch" Binding="{Binding Channel}" Width="35"/>
                                    <DataGridTextColumn Header="Device" Binding="{Binding DeviceModel}" Width="70"/>
                                    <DataGridTextColumn Header="Type" Binding="{Binding EventType}" Width="65"/>
                                    <DataGridTextColumn Header="Start" Binding="{Binding StartTime.TotalSeconds, Mode=OneWay, StringFormat=F3}" Width="55"/>
                                    <DataGridTextColumn Header="Dur." Binding="{Binding Duration.TotalSeconds, Mode=OneWay, StringFormat=F3}" Width="50"/>
                                    <DataGridTextColumn Header="End" Binding="{Binding EndTime.TotalSeconds, Mode=OneWay, StringFormat=F3}" Width="55"/>
                                    <DataGridTextColumn Header="Freq(Hz)" Binding="{Binding FrequencyDisplay}" Width="65"/>
                                    <DataGridTextColumn Header="Amp(V)" Binding="{Binding AmplitudeDisplay}" Width="60"/>
                                    <DataGridTextColumn Header="Offset(V)" Binding="{Binding OffsetDisplay}" Width="65"/>
                                    <DataGridTextColumn Header="Vmin(V)" Binding="{Binding VminDisplay}" Width="60"/>
                                    <DataGridTextColumn Header="Vmax(V)" Binding="{Binding VmaxDisplay}" Width="60"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </TabItem>
                </TabControl>
            </Grid>
        </Grid>

        <!-- Status Bar -->
        <StatusBar Grid.Row="2" Background="#34495E" Foreground="White" Height="25">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusText}"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Text="{Binding ExecutionStateText}"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Speed: " Margin="0,0,3,0"/>
                    <TextBlock Text="{Binding PlaybackSpeedText}" FontWeight="Bold" Foreground="#3498DB"/>
                    <TextBlock Text=" (Real-Time)" Margin="3,0,0,0" FontStyle="Italic"/>
                </StackPanel>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
