<Window x:Class="LAMP_DAQ_Control_v0_8.UI.WPF.Views.SignalManager.SignalManagerView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:controls="clr-namespace:LAMP_DAQ_Control_v0_8.UI.WPF.Controls"
        mc:Ignorable="d"
        Title="Signal Manager - LAMP DAQ Control" Height="700" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Menu Bar -->
            <RowDefinition Height="*"/>
            <!-- Content -->
            <RowDefinition Height="Auto"/>
            <!-- Status Bar -->
        </Grid.RowDefinitions>

        <!-- Menu Bar -->
        <Menu Grid.Row="0" Background="White" Padding="5">
            <MenuItem Header="_File">
                <MenuItem Header="_New Sequence" Command="{Binding NewSequenceCommand}"/>
                <MenuItem Header="_Open Sequence..." Command="{Binding OpenSequenceCommand}"/>
                <MenuItem Header="_Save Sequence" Command="{Binding SaveSequenceCommand}"/>
                <MenuItem Header="Save Sequence _As..." Command="{Binding SaveSequenceAsCommand}"/>
                <Separator/>
                <MenuItem Header="_Close" Command="{Binding CloseCommand}"/>
            </MenuItem>
            <MenuItem Header="_Edit">
                <MenuItem Header="_Add Event" Command="{Binding AddEventCommand}"/>
                <MenuItem Header="_Delete Event" Command="{Binding DeleteEventCommand}"/>
                <MenuItem Header="D_uplicate Event" Command="{Binding DuplicateEventCommand}"/>
            </MenuItem>
            <MenuItem Header="_Sequence">
                <MenuItem Header="_Validate" Command="{Binding ValidateCommand}"/>
                <MenuItem Header="_Execute" Command="{Binding ExecuteCommand}"/>
                <MenuItem Header="_Stop" Command="{Binding StopCommand}"/>
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="_About"/>
            </MenuItem>
        </Menu>

        <!-- Main Content -->
        <Grid Grid.Row="1" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/>
                <!-- Left Panel -->
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
                <!-- Center (Timeline) -->
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="300"/>
                <!-- Right Panel -->
            </Grid.ColumnDefinitions>

            <!-- Left Panel: Sequences & Library -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Sequences Section -->
                <TextBlock Grid.Row="0" Text="Sequences" FontWeight="Bold" FontSize="14" Margin="0,0,0,5"/>
                <Border Grid.Row="1" BorderBrush="#DDD" BorderThickness="1" Background="White" Margin="0,0,0,10">
                    <ListBox ItemsSource="{Binding Sequences}" 
                             SelectedItem="{Binding SelectedSequence}"
                             DisplayMemberPath="Name"/>
                </Border>

                <!-- Signal Library Section -->
                <TextBlock Grid.Row="2" Text="Signal Library" FontWeight="Bold" FontSize="14" Margin="0,10,0,5"/>
                <Border Grid.Row="3" BorderBrush="#DDD" BorderThickness="1" Background="White">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <TreeView ItemsSource="{Binding SignalCategories}" Background="White">
                        <TreeView.ItemContainerStyle>
                            <Style TargetType="TreeViewItem">
                                <Setter Property="IsExpanded" Value="True"/>
                                <Setter Property="Padding" Value="2"/>
                            </Style>
                        </TreeView.ItemContainerStyle>
                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate ItemsSource="{Binding Signals}">
                                <TextBlock Text="{Binding CategoryName}" 
                                           FontWeight="Bold" 
                                           FontSize="12"
                                           Foreground="#2C3E50"
                                           Margin="0,5,0,3"/>
                                <HierarchicalDataTemplate.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#E8F4F8" 
                                                Padding="8,4" 
                                                Margin="2,1" 
                                                CornerRadius="3"
                                                BorderBrush="#B0D4E3"
                                                BorderThickness="1"
                                                Cursor="Hand"
                                                MouseDown="OnSignalMouseDown"
                                                Tag="{Binding}">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#D0E8F2"/>
                                                            <Setter Property="BorderBrush" Value="#5DADE2"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding Name}" 
                                                       FontSize="11"
                                                       Foreground="#34495E"/>
                                        </Border>
                                    </DataTemplate>
                                </HierarchicalDataTemplate.ItemTemplate>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                    </ScrollViewer>
                </Border>
            </Grid>

            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" Background="#DDD"/>

            <!-- Center Panel: Timeline -->
            <Border Grid.Column="2" BorderBrush="#DDD" BorderThickness="1" Background="White">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <!-- Controls -->
                        <RowDefinition Height="*"/>
                        <!-- Timeline -->
                    </Grid.RowDefinitions>

                    <!-- Playback Controls -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Background="#F9F9F9" Margin="10">
                        <Button Content="▶ Play" Command="{Binding PlayCommand}" Width="80" Margin="0,0,5,0"/>
                        <Button Content="⏸ Pause" Command="{Binding PauseCommand}" Width="80" Margin="0,0,5,0"/>
                        <Button Content="⏹ Stop" Command="{Binding StopCommand}" Width="80" Margin="0,0,20,0"/>
                        <TextBlock Text="Time:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <TextBlock Text="{Binding CurrentTimeText}" VerticalAlignment="Center" FontWeight="Bold" MinWidth="60"/>
                        <Slider Value="{Binding CurrentTimeSeconds}" 
                                Maximum="{Binding TotalDurationSeconds}" 
                                Width="200" 
                                Margin="10,0,0,0"
                                VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Timeline View with Custom Control -->
                    <controls:TimelineControl Grid.Row="1" x:Name="TimelineControl" DataContext="{Binding}" MinHeight="400"/>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="3" Width="5" HorizontalAlignment="Stretch" Background="#DDD"/>

            <!-- Right Panel: Event Details -->
            <Grid Grid.Column="4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Event Details" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
                
                <Border Grid.Row="1" BorderBrush="#DDD" BorderThickness="1" Background="White" Padding="10">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="Name:" FontWeight="Bold" Margin="0,0,0,5"/>
                            <TextBox Text="{Binding SelectedEvent.Name, UpdateSourceTrigger=PropertyChanged}" 
                                     Margin="0,0,0,10"/>

                            <TextBlock Text="Event Type:" FontWeight="Bold" Margin="0,0,0,5"/>
                            <ComboBox SelectedItem="{Binding SelectedEvent.EventType}" 
                                      Margin="0,0,0,10"/>

                            <TextBlock Text="Channel:" FontWeight="Bold" Margin="0,0,0,5"/>
                            <TextBox Text="{Binding SelectedEvent.Channel, UpdateSourceTrigger=PropertyChanged}" 
                                     Margin="0,0,0,10"/>

                            <TextBlock Text="Start Time (s):" FontWeight="Bold" Margin="0,0,0,5"/>
                            <TextBox Text="{Binding SelectedEventStartSeconds, UpdateSourceTrigger=PropertyChanged}" 
                                     Margin="0,0,0,10"/>

                            <TextBlock Text="Duration (ms):" FontWeight="Bold" Margin="0,0,0,5"/>
                            <TextBox Text="{Binding SelectedEventDurationMs, UpdateSourceTrigger=PropertyChanged}" 
                                     Margin="0,0,0,10"/>

                            <TextBlock Text="Description:" FontWeight="Bold" Margin="0,0,0,5"/>
                            <TextBox Text="{Binding SelectedEvent.Description, UpdateSourceTrigger=PropertyChanged}" 
                                     TextWrapping="Wrap" 
                                     AcceptsReturn="True" 
                                     Height="60" 
                                     Margin="0,0,0,10"/>

                            <Button Content="Apply Changes" Command="{Binding ApplyEventChangesCommand}" 
                                    HorizontalAlignment="Stretch" 
                                    Padding="10,5"/>
                        </StackPanel>
                    </ScrollViewer>
                </Border>

                <StackPanel Grid.Row="2" Margin="0,10,0,0">
                    <Button Content="Delete Event" Command="{Binding DeleteEventCommand}" 
                            Background="#E74C3C" Foreground="White" 
                            Padding="10,5" Margin="0,0,0,5"/>
                    <Button Content="Duplicate Event" Command="{Binding DuplicateEventCommand}" 
                            Padding="10,5"/>
                </StackPanel>
            </Grid>
        </Grid>

        <!-- Status Bar -->
        <StatusBar Grid.Row="2" Background="#34495E" Foreground="White" Height="25">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusText}"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Text="{Binding ExecutionStateText}"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
