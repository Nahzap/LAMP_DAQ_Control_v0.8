<UserControl x:Class="LAMP_DAQ_Control_v0_8.UI.WPF.Views.DigitalControlPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:LAMP_DAQ_Control_v0_8.UI.WPF.Views">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- HEADER -->
        <Border Grid.Row="0" Background="#34495E" Padding="10,8">
            <TextBlock Text="CONTROL DIGITAL - PCI-1735U (32 CANALES I/O)" FontSize="14" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
        </Border>
        
        <!-- CONTENIDO 2x2 -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <!-- CUADRANTE SUPERIOR IZQUIERDO: Monitoreo -->
            <GroupBox Grid.Row="0" Grid.Column="0" Header="MONITOREO DE ENTRADAS (DI)" Margin="5" Padding="8" FontWeight="Bold" Foreground="#2C3E50" Background="White">
                <StackPanel>
                    <Label Content="Frecuencia (Hz):" FontWeight="Normal"/>
                    <TextBox Text="{Binding ReadFrequency, UpdateSourceTrigger=PropertyChanged}" 
                             Margin="0,0,0,8"
                             ToolTip="Frecuencia de lectura (5-100 Hz)&#x0a;Óptimo: 10 Hz (uso general)&#x0a;Tiempo real: 50-100 Hz&#x0a;Data logging: 5 Hz"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8">
                        <Button Content="INICIAR" Command="{Binding StartMonitoringCommand}" Background="#27AE60" Foreground="White" Width="100" Height="32" Margin="3"/>
                        <Button Content="DETENER" Command="{Binding StopMonitoringCommand}" Background="#E74C3C" Foreground="White" Width="100" Height="32" Margin="3"/>
                    </StackPanel>
                    <Border Background="#ECF0F1" Padding="8" CornerRadius="4" Margin="0,8,0,0">
                        <TextBlock HorizontalAlignment="Center" FontSize="13">
                            <Run Text="Estado: " FontWeight="Bold"/>
                            <Run Text="{Binding IsMonitoring, Converter={StaticResource BoolToStringConverter}, ConverterParameter='ACTIVO|DETENIDO'}" FontWeight="Bold" Foreground="{Binding IsMonitoring, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='Green|Red'}"/>
                        </TextBlock>
                    </Border>
                </StackPanel>
            </GroupBox>
            
            <!-- CUADRANTE INFERIOR IZQUIERDO: Control Rápido -->
            <GroupBox Grid.Row="1" Grid.Column="0" Header="CONTROL RAPIDO (DO)" Margin="5" Padding="8" FontWeight="Bold" Foreground="#2C3E50" Background="White">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Label Grid.Row="0" Grid.Column="0" Content="Puerto:" FontWeight="Normal"/>
                        <TextBox Grid.Row="0" Grid.Column="1" x:Name="WritePortNumber" Text="0" Margin="3,0,0,3"/>
                        <Label Grid.Row="1" Grid.Column="0" Content="Valor:" FontWeight="Normal"/>
                        <TextBox Grid.Row="1" Grid.Column="1" x:Name="WritePortValue" Text="0" Margin="3,0,0,3"/>
                    </Grid>
                    <Button Content="ESCRIBIR PUERTO" Click="OnWritePortClick" Background="#3498DB" Foreground="White" Height="28" Margin="0,8" FontWeight="Bold" FontSize="11"/>
                    <Separator Margin="0,3"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,0">
                        <Button Content="RESET" Click="OnResetAllPortsClick" Background="#95A5A6" Foreground="White" Width="95" Height="26" Margin="3,0" FontSize="10"/>
                        <Button Content="ALL ON" Click="OnSetAllPortsClick" Background="#F39C12" Foreground="White" Width="95" Height="26" Margin="3,0" FontSize="10"/>
                    </StackPanel>
                </StackPanel>
            </GroupBox>
            
            <!-- CUADRANTE SUPERIOR DERECHO: Estados ENTRADAS + SALIDAS -->
            <TabControl Grid.Row="0" Grid.Column="1" Margin="5" Background="White" BorderBrush="#BDC3C7" BorderThickness="1">
                <TabItem Header="ENTRADAS (DI)" Foreground="#27AE60" FontWeight="Bold">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="5">
                            <TextBlock Text="Estado de entradas digitales (lectura):" FontStyle="Italic" FontSize="10" Margin="0,0,0,5"/>
                            <StackPanel Orientation="Horizontal" Margin="0,2">
                                <TextBlock Text="P0:" FontWeight="Bold" Width="25"/>
                                <ItemsControl ItemsSource="{Binding Port0Bits}">
                                    <ItemsControl.ItemsPanel><ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Width="18" Height="18" Margin="1" BorderBrush="#7F8C8D" BorderThickness="1" CornerRadius="2">
                                                <Border.Background><SolidColorBrush Color="{Binding Converter={StaticResource BoolToColorConverter}}"/></Border.Background>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,2">
                                <TextBlock Text="P1:" FontWeight="Bold" Width="25"/>
                                <ItemsControl ItemsSource="{Binding Port1Bits}">
                                    <ItemsControl.ItemsPanel><ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Width="18" Height="18" Margin="1" BorderBrush="#7F8C8D" BorderThickness="1" CornerRadius="2">
                                                <Border.Background><SolidColorBrush Color="{Binding Converter={StaticResource BoolToColorConverter}}"/></Border.Background>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,2">
                                <TextBlock Text="P2:" FontWeight="Bold" Width="25"/>
                                <ItemsControl ItemsSource="{Binding Port2Bits}">
                                    <ItemsControl.ItemsPanel><ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Width="18" Height="18" Margin="1" BorderBrush="#7F8C8D" BorderThickness="1" CornerRadius="2">
                                                <Border.Background><SolidColorBrush Color="{Binding Converter={StaticResource BoolToColorConverter}}"/></Border.Background>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,2">
                                <TextBlock Text="P3:" FontWeight="Bold" Width="25"/>
                                <ItemsControl ItemsSource="{Binding Port3Bits}">
                                    <ItemsControl.ItemsPanel><ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Width="18" Height="18" Margin="1" BorderBrush="#7F8C8D" BorderThickness="1" CornerRadius="2">
                                                <Border.Background><SolidColorBrush Color="{Binding Converter={StaticResource BoolToColorConverter}}"/></Border.Background>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
                <TabItem Header="SALIDAS (DO)" Foreground="#E74C3C" FontWeight="Bold">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="5">
                            <TextBlock Text="Estado de salidas digitales (comandadas):" FontStyle="Italic" FontSize="10" Margin="0,0,0,5"/>
                            <StackPanel x:Name="OutputStatesPanel">
                                <!-- Se actualizará dinámicamente desde code-behind -->
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
            </TabControl>
            
            <!-- CUADRANTE INFERIOR DERECHO: Control Bit por Bit -->
            <GroupBox Grid.Row="1" Grid.Column="1" Header="CONTROL BIT POR BIT (DO)" Margin="5" Padding="5" FontWeight="Bold" Foreground="#2C3E50" Background="White">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="P0:" FontWeight="Bold" Foreground="#E74C3C" FontSize="11" Margin="0,2"/>
                        <WrapPanel>
                            <CheckBox Content="0" Margin="2" Click="OnBitToggle" Tag="0,0" FontSize="9" Width="28"/>
                            <CheckBox Content="1" Margin="2" Click="OnBitToggle" Tag="0,1" FontSize="9" Width="28"/>
                            <CheckBox Content="2" Margin="2" Click="OnBitToggle" Tag="0,2" FontSize="9" Width="28"/>
                            <CheckBox Content="3" Margin="2" Click="OnBitToggle" Tag="0,3" FontSize="9" Width="28"/>
                            <CheckBox Content="4" Margin="2" Click="OnBitToggle" Tag="0,4" FontSize="9" Width="28"/>
                            <CheckBox Content="5" Margin="2" Click="OnBitToggle" Tag="0,5" FontSize="9" Width="28"/>
                            <CheckBox Content="6" Margin="2" Click="OnBitToggle" Tag="0,6" FontSize="9" Width="28"/>
                            <CheckBox Content="7" Margin="2" Click="OnBitToggle" Tag="0,7" FontSize="9" Width="28"/>
                        </WrapPanel>
                        <TextBlock Text="P1:" FontWeight="Bold" Foreground="#E74C3C" FontSize="11" Margin="0,3,0,2"/>
                        <WrapPanel>
                            <CheckBox Content="0" Margin="2" Click="OnBitToggle" Tag="1,0" FontSize="9" Width="28"/>
                            <CheckBox Content="1" Margin="2" Click="OnBitToggle" Tag="1,1" FontSize="9" Width="28"/>
                            <CheckBox Content="2" Margin="2" Click="OnBitToggle" Tag="1,2" FontSize="9" Width="28"/>
                            <CheckBox Content="3" Margin="2" Click="OnBitToggle" Tag="1,3" FontSize="9" Width="28"/>
                            <CheckBox Content="4" Margin="2" Click="OnBitToggle" Tag="1,4" FontSize="9" Width="28"/>
                            <CheckBox Content="5" Margin="2" Click="OnBitToggle" Tag="1,5" FontSize="9" Width="28"/>
                            <CheckBox Content="6" Margin="2" Click="OnBitToggle" Tag="1,6" FontSize="9" Width="28"/>
                            <CheckBox Content="7" Margin="2" Click="OnBitToggle" Tag="1,7" FontSize="9" Width="28"/>
                        </WrapPanel>
                        <TextBlock Text="P2:" FontWeight="Bold" Foreground="#E74C3C" FontSize="11" Margin="0,3,0,2"/>
                        <WrapPanel>
                            <CheckBox Content="0" Margin="2" Click="OnBitToggle" Tag="2,0" FontSize="9" Width="28"/>
                            <CheckBox Content="1" Margin="2" Click="OnBitToggle" Tag="2,1" FontSize="9" Width="28"/>
                            <CheckBox Content="2" Margin="2" Click="OnBitToggle" Tag="2,2" FontSize="9" Width="28"/>
                            <CheckBox Content="3" Margin="2" Click="OnBitToggle" Tag="2,3" FontSize="9" Width="28"/>
                            <CheckBox Content="4" Margin="2" Click="OnBitToggle" Tag="2,4" FontSize="9" Width="28"/>
                            <CheckBox Content="5" Margin="2" Click="OnBitToggle" Tag="2,5" FontSize="9" Width="28"/>
                            <CheckBox Content="6" Margin="2" Click="OnBitToggle" Tag="2,6" FontSize="9" Width="28"/>
                            <CheckBox Content="7" Margin="2" Click="OnBitToggle" Tag="2,7" FontSize="9" Width="28"/>
                        </WrapPanel>
                        <TextBlock Text="P3:" FontWeight="Bold" Foreground="#E74C3C" FontSize="11" Margin="0,3,0,2"/>
                        <WrapPanel>
                            <CheckBox Content="0" Margin="2" Click="OnBitToggle" Tag="3,0" FontSize="9" Width="28"/>
                            <CheckBox Content="1" Margin="2" Click="OnBitToggle" Tag="3,1" FontSize="9" Width="28"/>
                            <CheckBox Content="2" Margin="2" Click="OnBitToggle" Tag="3,2" FontSize="9" Width="28"/>
                            <CheckBox Content="3" Margin="2" Click="OnBitToggle" Tag="3,3" FontSize="9" Width="28"/>
                            <CheckBox Content="4" Margin="2" Click="OnBitToggle" Tag="3,4" FontSize="9" Width="28"/>
                            <CheckBox Content="5" Margin="2" Click="OnBitToggle" Tag="3,5" FontSize="9" Width="28"/>
                            <CheckBox Content="6" Margin="2" Click="OnBitToggle" Tag="3,6" FontSize="9" Width="28"/>
                            <CheckBox Content="7" Margin="2" Click="OnBitToggle" Tag="3,7" FontSize="9" Width="28"/>
                        </WrapPanel>
                    </StackPanel>
                </ScrollViewer>
            </GroupBox>
        </Grid>
    </Grid>
</UserControl>
